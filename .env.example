# --- Gemini (required for live AI chat, tools, personalization) ---
# https://aistudio.google.com/apikey
# Users can also save a per-device key in Profile (no restart needed).
GEMINI_API_KEY=

# false = always use real API when a key exists; true = mock only when no key
USE_MOCK_API=false

# Optional
# GEMINI_MODEL=gemini-2.5-flash

# --- Google Maps Embed (optional; basic embed works without a key) ---
# Users can also save per-device in Profile.
GOOGLE_MAPS_API_KEY=

# --- Google Cloud Project (required for Firestore) ---
# Cloud Run 上會自動偵測，本機開發需要設定
GOOGLE_CLOUD_PROJECT=your-project-id
TTS_ENABLED=true
STT_ENABLED=true

# --- Google Cloud TTS / STT (server admin only — do NOT put in Profile) ---
# Create a service account with Cloud Text-to-Speech + Speech-to-Text APIs enabled.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
TTS_ENABLED=true
STT_ENABLED=true
